{
  "expo": {
    "name": "ChildrenEng",
    "slug": "ChildrenEng",
    "version": "1.0.0",
    "description": "English learning app for kids with pictures, speech, and mini-games.",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "childreneng",
    "userInterfaceStyle": "light",
    "primaryColor": "#3D9CAD",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.emberlast.ChildrenEng",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleDisplayName": "ChildrenEng",
        "NSMotionUsageDescription": "The app uses device tilt for gentle background animation on some screens.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.emberlast.ChildrenEng",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3D9CAD"
      },
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "PORTRAIT_UP"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#3D9CAD",
          "dark": {
            "backgroundColor": "#2E8594"
          }
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b73d42ee-7b16-4cfd-b3f0-6c33f37feda4"
      }
    },
    "owner": "emberlast1"
  }
}
